generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model eventos {
  id                Int            @id @default(autoincrement())
  titulo            String
  descricao         String
  data_evento       DateTime
  local             String
  capacidade_maxima Int
  status            eventos_status @default(ATIVO)
  inscricoes        inscricoes[]

  imagens           imagem[]
}

model inscricoes {
  id             Int               @id @default(autoincrement())
  data_inscricao DateTime          @default(now())
  status         inscricoes_status @default(CONFIRMADA)
  usuariosId     Int
  eventosId      Int
  eventos        eventos           @relation(fields: [eventosId], references: [id], map: "Inscricoes_eventosId_fkey")
  usuarios       usuarios          @relation(fields: [usuariosId], references: [id], map: "Inscricoes_usuariosId_fkey")

  @@index([eventosId], map: "Inscricoes_eventosId_fkey")
  @@index([usuariosId], map: "Inscricoes_usuariosId_fkey")
}

model usuarios {
  id            Int          @id @default(autoincrement())
  nome          String
  senha         String
  data_cadastro DateTime     @default(now())
  inscricoes    inscricoes[]
}

model imagem {
  id            Int     @id @default(autoincrement())
  nomeOriginal  String
  nomeArquivo   String
  mimeType      String
  path          String

  eventosId     Int
  eventos       eventos @relation(fields: [eventosId], references: [id])
}

enum inscricoes_status {
  CANCELADA
  CONFIRMADA
  LISTA_ESPERA
}

enum eventos_status {
  ATIVO
  CANCELADO
  ENCERRAMENTO
}